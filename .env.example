# API Keys Configuration
# Copy this file to .env and fill in your actual API keys

# Groq API (for LLM inference)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Tavily API (for web search)
# Get your key at: https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ScrapeGraph API (for web scraping)
# Get your key at: https://scrapegraph.ai/
SCRAPEGRAPH_API_KEY=your_scrapegraph_api_key_here

# AgentOps API (for monitoring)
# Get your key at: https://www.agentops.ai/
AGENTOPS_API_KEY=your_agentops_api_key_here

# Optional: OpenAI API (if using OpenAI models)
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic API (if using Claude models)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
